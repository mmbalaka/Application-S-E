# Environnement virtuel Python
.venv/

# Base de données locale (données réelles — ne pas publier sur un dépôt public)
db.sqlite3

# Fichiers téléversés (justificatifs — données réelles)
media/

# Caches Python
__pycache__/
*.pyc

# Fichiers statiques collectés (régénérés au déploiement)
staticfiles/

# Fichiers de config locaux / secrets
.env
